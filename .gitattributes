# Git line ending configuration
# https://help.github.com/articles/dealing-with-line-endings/

# Windows: CRLF, macOS/Linux: LF
* text=auto

# Explicitly declare source files to use LF
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Shell scripts should use LF
*.sh text eol=lf
*.bash text eol=lf

# Batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Images and binaries - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.dll binary
*.exe binary
*.lib binary
*.a binary
*.so binary
*.dylib binary

# Documentation
*.pdf binary
